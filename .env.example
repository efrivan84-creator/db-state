# Copy to .env to override demo2 MongoDB connection.
# Without these, demo2 connects to mongodb://localhost:27017 (no auth).

# Option A — single URI (highest priority, overrides USER/PASSWORD/HOST):
# DB_STATE_MONGO_URI=mongodb://user:pass@host:port/?authSource=admin

# Option B — separate parts (used when URI is unset):
# DB_STATE_MONGO_USER=
# DB_STATE_MONGO_PASSWORD=
# DB_STATE_MONGO_HOST=localhost:27017

# Database name (default: db_state_demo2)
# DB_STATE_MONGO_DB=db_state_demo2

# WebSocket port for demo2 server (default: 8788)
# DB_STATE_DEMO2_PORT=8788

# WebSocket port for demo (simpler) server (default: 8787)
# DB_STATE_DEMO_PORT=8787
